    # Database
DATABASE_URL="postgresql://user:password@localhost:5432/trackly?schema=public"

# Authentication (NextAuth)
AUTH_SECRET="your_nextauth_secret_here" # Generate one with `openssl rand -base64 32`

# GitHub OAuth
AUTH_GITHUB_ID="your_github_id_here"
AUTH_GITHUB_SECRET="your_github_secret_here"

# Google OAuth
AUTH_GOOGLE_ID="your_google_id_here"
AUTH_GOOGLE_SECRET="your_google_secret_here"

# Resend (Email)
RESEND_API_KEY="re_your_resend_api_key_here"

# Cron Jobs
CRON_SECRET="your_cron_secret_here"
